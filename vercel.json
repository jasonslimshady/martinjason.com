{
  "cleanUrls": true,
  "trailingSlash": false,
  "framework": null,
  "outputDirectory": ".",
  "redirects": [
    {
      "source": "/iphone-fotos-ki-produktgalerie",
      "destination": "/aus-iphone-fotos-eine-komplette-AI-Galerie-f%C3%BCr-eine-Produktseite-generieren",
      "statusCode": 301
    }
  ],
  "headers": [
    {
      "source": "/(.*\\.(avif|webp|png|jpg|jpeg|svg|woff2|woff|ttf|otf|ico|gif))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.(css|js))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/(.*\\.html)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
