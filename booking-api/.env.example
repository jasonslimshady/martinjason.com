# ─── Anthropic ───────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ─── Google OAuth2 ───────────────────────────────────────────────────────────
# Create these in Google Cloud Console → APIs & Services → Credentials
# (see SETUP.md for the full step-by-step)
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx

# Run `npm run token` to generate this once — store the value here
GOOGLE_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxxxxxx

# ─── Calendar & Email ────────────────────────────────────────────────────────
# The Google Calendar + Gmail account to use for bookings
CALENDAR_ID=jasonmartinde@gmail.com

# ─── CORS ────────────────────────────────────────────────────────────────────
# Your live website origin (no trailing slash)
FRONTEND_ORIGIN=https://martinjason.com
